<?xml version="1.0" ?>
<sdf version="1.7">
  <world name="default">

    <gravity>0 0 -9.81</gravity>

    <physics type="bullet" name="bullet_physics">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <ambient>0.2 0.5 0.5 1</ambient>
    <background>0.2 0.2 0.2 1</background>

    <model name="custom_ground">
      <static>true</static>
      <link name="ground_link">
        <pose>0 0 0 0 0 0</pose>

        <collision name="ground_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.6</mu>
                <mu2>0.4</mu2>
                <kp>100000</kp> 
                <kd>1</kd>
              </ode>
            </friction>
          </surface>
        </collision>

        <visual name="ground_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/White</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>