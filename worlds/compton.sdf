          </geometry>
        </visual>
      </link>
      <link name="step_06">
        <pose>3.2 0 0.55 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.4 1.0 0.1</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.4 1.0 0.1</size>
            </box>
          </geometry>
        </visual>
      </link>
      <link name="step_07">
        <pose>3.6 0 0.65 0 0 0</pose>
        <collision name="collision">
          <geometry>
